{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://koptelov-vk.github.io/tenant-mix-dashboard/build-info.schema.json",
  "title": "Tenant Mix production build metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "build",
    "generatedAt",
    "app",
    "appVersion",
    "dataVersion",
    "dataSnapshotAt",
    "methodologyVersion",
    "classifierVersion",
    "deploymentId"
  ],
  "properties": {
    "status": { "const": "production" },
    "build": { "type": "string", "minLength": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "app": { "const": "tenant-mix-react" },
    "appVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "dataVersion": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}$" },
    "dataSnapshotAt": { "type": "string", "format": "date" },
    "methodologyVersion": { "type": "string", "minLength": 1 },
    "classifierVersion": { "type": "string", "minLength": 1 },
    "deploymentId": { "type": "string", "minLength": 1 }
  }
}
